# Ports
KAFKA_PORT=9092
KAFKA_UI_PORT=8080
AIRFLOW_POSTGRES_PORT=5432
ANALYTICS_POSTGRES_PORT=5433
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8081
AIRFLOW_UI_PORT=8082
STREAMLIT_PORT=8501

# Kafka
KAFKA_NODE_ID=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=stock_bars_raw
KAFKA_TOPIC_FUNDAMENTALS=stock_fundamentals_raw
KAFKA_TOPIC_DIVIDENDS=stock_dividends_raw
KAFKA_TOPIC_EARNINGS=stock_earnings_raw
KAFKA_CONSUMER_GROUP=streamflow-ingestor
SPARK_MASTER_URL=spark://spark-master:7077

# MinIO / S3
S3_ENDPOINT_INTERNAL=http://minio:9000
S3_ENDPOINT_EXTERNAL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_DATALAKE_BUCKET=datalake

# Airflow metadata DB
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_FERNET_KEY=2VGiNvoB0qhlxDMs1EbozR5sVSIJc68BgUlnFLuz_zI=
AIRFLOW_WEBSERVER_SECRET_KEY=streamflow-secret-key

# Analytics DB
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=analytics

# Pipeline defaults
STOCK_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,META

# Bronze streaming scalability
BRONZE_CHECKPOINT_PATH=s3a://datalake/checkpoints/stock_bars_raw
BRONZE_QUARANTINE_PATH=s3a://datalake/quarantine/stock_bars
BRONZE_QUARANTINE_TABLE=public.stock_bars_quarantine
BRONZE_STARTING_OFFSETS=earliest
BRONZE_MAX_OFFSETS_PER_TRIGGER=200000
BRONZE_FAIL_ON_DATA_LOSS=false
BRONZE_STREAM_PROCESSING_TIME=1 minute
SPARK_SQL_SHUFFLE_PARTITIONS=48
